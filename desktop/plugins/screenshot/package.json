{
  "name": "omniaide-screenshot",
  "version": "1.0.0",
  "displayName": "截图",
  "description": "快速截图和标注",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build"
  },
  "omniaide": {
    "id": "screenshot",
    "displayName": "截图",
    "icon": "Camera",
    "keywords": ["ss"],
    "permissions": ["screenshot", "notification"],
    "builtin": true
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vue": "^3.5.40",
    "typescript": "~5.6.0"
  }
}
