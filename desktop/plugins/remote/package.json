{
  "name": "omniaide-remote",
  "version": "1.0.0",
  "displayName": "远程控制",
  "description": "WebRTC 远程桌面控制",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node ../../scripts/build-frontends.mjs",
    "build:plugin": "vite build",
    "build:frontend": "node ../../scripts/build-frontends.mjs"
  },
  "omniaide": {
    "id": "remote",
    "displayName": "远程控制",
    "icon": "Monitor",
    "keywords": ["remote", "control", "screen"],
    "permissions": ["storage", "notification", "shell", "remote"],
    "builtin": true
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "vite": "^5.2.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "vue": "^3.5.40",
    "typescript": "~5.6.0"
  }
}
