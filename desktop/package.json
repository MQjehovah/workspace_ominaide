{
  "name": "omniaide-desktop",
  "version": "1.1.0",
  "description": "OmniAide Desktop - Plugin-based AI Workbench",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/build-plugins.mjs && node scripts/build-frontends.mjs && vite build && electron-builder",
    "build-frontends": "node scripts/build-frontends.mjs",
    "migrate-plugins": "node scripts/migrate-to-unified.mjs",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@tiptap/extension-image": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-table-cell": "^3.28.0",
    "@tiptap/extension-table-header": "^3.28.0",
    "@tiptap/extension-table-row": "^3.28.0",
    "@tiptap/extension-underline": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/static-renderer": "^3.28.0",
    "@tiptap/vue-3": "^3.28.0",
    "axios": "^1.7.0",
    "chokidar": "^3.6.0",
    "element-plus": "^2.5.0",
    "lowdb": "^7.0.0",
    "pinia": "^2.1.0",
    "prosemirror-markdown": "^1.13.5",
    "vue": "^3.5.40",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "~5.6.0",
    "vite": "^5.2.0",
    "vite-plugin-electron": "^0.28.0",
    "vue-tsc": "^2.0.0"
  },
  "build": {
    "appId": "com.omniaide.desktop",
    "productName": "OmniAide",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "npmRebuild": true
  }
}
